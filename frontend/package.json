{
  "name": "fava-lazy-beancount-frontend",
  "private": true,
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --format=esm --loader:.css=file --outfile=../src/fava_lazy_beancount/FavaLazyBeancount.js --minify",
